# ── Server connection ──────────────────────────────────────────────────────────
SPHOTEL_API_URL=https://yourdomain.com    # The URL of your deployed sphotel backend

# ── Agent API Key (set automatically after activation) ─────────────────────────
# Do NOT set this manually — run: python -m agent --register --token <TOKEN> --name "Counter Printer"
# The key is saved to ~/.sphotel-agent/.agent_key automatically.
# AGENT_API_KEY=

# ── Printer configuration ──────────────────────────────────────────────────────
# Printer type: usb | network | file
PRINTER_TYPE=network

# Network printer (most common for thermal printers on WiFi/LAN)
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9100

# USB printer — override vendor/product IDs for your model
# Epson TM-T20 defaults (0x04b8 / 0x0202); Star TSP100 would be 0x0519 / 0x0003
USB_VENDOR_ID=0x04b8
USB_PRODUCT_ID=0x0202

# File / CUPS path (Linux)
PRINTER_FILE=/dev/usb/lp0

# ── Paper width ────────────────────────────────────────────────────────────────
# 32 chars = 58mm paper | 42 chars = 80mm paper
RECEIPT_WIDTH=42
POLL_INTERVAL_SECONDS=3

# ── Optional: printer name filter ─────────────────────────────────────────────
# If you have multiple agents, set this to route jobs for a specific printer
PRINTER_NAME=

# ── Auto-update (set by server; no action needed here) ───────────────────────
# AGENT_DOWNLOAD_URL and AGENT_SHA256 are returned by /api/v1/print/agents/version
